<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Estilo personalizado para EditText con mejor visibilidad -->
    <style name="CustomEditText" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">#1F1F1F</item>
        <item name="android:textColorHint">#757575</item>
        <item name="android:background">@drawable/edittext_custom_border</item>
        <item name="android:padding">12dp</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Estilo para botones del menú principal -->
    <style name="MenuButton" parent="Widget.AppCompat.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:padding">12dp</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>
</resources>