<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 PROCTOR 4 PUNTOS"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#E67E22"
            android:layout_marginBottom="8dp"/>

        <!-- Selector de tipo -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tipo de ensayo:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#E67E22"
            android:layout_marginTop="8dp"/>

        <RadioGroup
            android:id="@+id/rgTipoProctor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <RadioButton
                android:id="@+id/rbEstandar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Estándar (ASTM D698)"
                android:checked="true"
                android:textSize="14sp"/>

            <RadioButton
                android:id="@+id/rbModificado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Modificado (ASTM D1557)"
                android:textSize="14sp"/>
        </RadioGroup>

        <!-- DATOS DEL MOLDE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DATOS DEL MOLDE"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#E67E22"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Volumen (cm³):"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etVolumenMolde"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="numberDecimal"
                android:hint="ejemplo 944"
                android:text=""
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Peso molde (g):"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etPesoMolde"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="numberDecimal"
                android:hint="ejemplo 5107.2"
                android:text=""
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- TABLA DE 4 MUESTRAS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MUESTRAS"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#E67E22"
            android:layout_marginTop="8dp"/>

        <!-- Encabezados -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E67E22"
            android:padding="8dp"
            android:layout_marginTop="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Muestra"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="Peso molde+suelo (g)"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Humedad (%)"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Muestra 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1"
                android:gravity="center"/>

            <EditText
                android:id="@+id/etPeso1"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:inputType="numberDecimal"
                android:hint=""
                android:text=""
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etHum1"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="numberDecimal"
                android:hint=""
                android:text=""
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Muestra 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2"
                android:gravity="center"/>

            <EditText
                android:id="@+id/etPeso2"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:inputType="numberDecimal"
                android:hint=""
                android:text=""
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etHum2"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="numberDecimal"
                android:hint=""
                android:text=""
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Muestra 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="3"
                android:gravity="center"/>

            <EditText
                android:id="@+id/etPeso3"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:inputType="numberDecimal"
                android:hint=""
                android:text=""
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etHum3"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="numberDecimal"
                android:hint=""
                android:text=""
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Muestra 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="4"
                android:gravity="center"/>

            <EditText
                android:id="@+id/etPeso4"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:inputType="numberDecimal"
                android:hint=""
                android:text=""
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etHum4"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="numberDecimal"
                android:hint=""
                android:text=""
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- CORRECCIÓN POR GRUESOS (OPCIONAL) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ CORRECCIÓN POR GRUESOS (OPCIONAL)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#E67E22"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Si se deja vacío, calcula Proctor normal"
            android:textSize="12sp"
            android:textColor="#7F8C8D"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="% fracción gruesa (>#4):"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etPorcentajeGrueso"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="numberDecimal"
                android:hint="ej: 17.0"
                android:text=""
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Gravedad específica (Gs):"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etGs"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="numberDecimal"
                android:hint="ej: 2.65"
                android:text=""
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Botón Calcular -->
        <Button
            android:id="@+id/btnCalcularProctor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CALCULAR PROCTOR"
            android:backgroundTint="#E67E22"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <!-- GRÁFICA -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CURVA PROCTOR"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#E67E22"
            android:layout_marginBottom="8dp"/>

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/chartProctor"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="16dp"/>

        <!-- RESULTADOS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RESULTADOS"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#E67E22"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Densidad máxima:"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvDensidadMaxima"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:gravity="end"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Humedad óptima:"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvHumedadOptima"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:gravity="end"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Resultados corregidos (aparecen solo si aplica) -->
        <TextView
            android:id="@+id/tvTituloCorregido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RESULTADOS CORREGIDOS"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#E67E22"
            android:layout_marginTop="12dp"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/layoutCorregido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:padding="8dp"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Densidad corregida:"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvDensidadCorregida"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="-"
                    android:gravity="end"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#F5F5F5"
                android:padding="8dp"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Humedad corregida:"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvHumedadCorregida"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="-"
                    android:gravity="end"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Mensaje de validación -->
        <TextView
            android:id="@+id/tvMensajeProctor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:gravity="center"
            android:padding="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"/>

        <!-- Botón Volver -->
        <Button
            android:id="@+id/btnVolverProctor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="← Volver al menú"
            android:backgroundTint="#7F8C8D"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp"/>

    </LinearLayout>
</ScrollView>