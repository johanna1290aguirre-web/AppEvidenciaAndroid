<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⛰️ DENSIDAD DE CAMPO"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#9B59B6"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cono de Arena - ASTM D1556"
            android:textSize="14sp"
            android:gravity="center"
            android:textColor="#7F8C8D"
            android:layout_marginBottom="20dp"/>

        <!-- DATOS PROCTOR -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 DATOS PROCTOR (para % compactación)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#9B59B6"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Densidad máxima:"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etDensidadMaxima"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="numberDecimal"
                android:hint="ej: 1.765"
                android:text=""
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Humedad óptima:"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etHumedadOptima"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="numberDecimal"
                android:hint="ej: 20.2"
                android:text=""
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- DATOS DEL ENSAYO -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔧 DATOS DEL ENSAYO"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#9B59B6"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Peso inicial aparato+arena:"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etPesoInicial"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="numberDecimal"
                android:hint="ej: 5717"
                android:text=""
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Peso final aparato+arena:"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etPesoFinal"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="numberDecimal"
                android:hint="ej: 2463"
                android:text=""
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Peso arena embudo+placa:"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etPesoEmbudoPlaca"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="numberDecimal"
                android:hint="ej: 1472"
                android:text=""
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Densidad de la arena:"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etDensidadArena"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="numberDecimal"
                android:hint="ej: 1.320"
                android:text=""
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- DATOS DEL SUELO -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🪨 DATOS DEL SUELO"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#9B59B6"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Peso suelo húmedo+recip:"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etPesoHumedo"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="numberDecimal"
                android:hint="ej: 2543"
                android:text=""
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Humedad del suelo (%):"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etHumedadSuelo"
                style="@style/CustomEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="numberDecimal"
                android:hint="ej: 19.2"
                android:text=""
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Botón Calcular -->
        <Button
            android:id="@+id/btnCalcularDensidad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CALCULAR DENSIDAD DE CAMPO"
            android:backgroundTint="#9B59B6"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <!-- RESULTADOS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RESULTADOS"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#9B59B6"
            android:layout_marginBottom="8dp"/>

        <!-- Volumen del hueco -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VOLUMEN DEL HUECO"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#34495E"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Masa arena total hueco:"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvMasaTotalHueco"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:gravity="end"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Masa arena solo hueco:"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvMasaSoloHueco"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:gravity="end"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Volumen del hueco:"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvVolumenHueco"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:gravity="end"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Masa seca -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MASA SECA DEL SUELO"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#34495E"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Masa seca:"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvMasaSeca"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:gravity="end"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Densidades -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DENSIDADES"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#34495E"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Densidad húmeda:"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvDensidadHumeda"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:gravity="end"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Densidad seca:"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvDensidadSeca"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:gravity="end"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Peso unitario seco:"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvPesoUnitario"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:gravity="end"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Compactación -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="COMPACTACIÓN"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#34495E"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Grado de compactación:"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvCompactacion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:gravity="end"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvMensajeCompactacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:gravity="center"
            android:padding="8dp"
            android:layout_marginBottom="16dp"/>

        <!-- Botón Volver -->
        <Button
            android:id="@+id/btnVolverDensidad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="← Volver al menú"
            android:backgroundTint="#7F8C8D"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp"/>

    </LinearLayout>
</ScrollView>